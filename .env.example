# Site
# Production example: https://your-domain.com
# Google OAuth redirect URI for this app is: ${NEXT_PUBLIC_SITE_URL}/auth/callback
NEXT_PUBLIC_SITE_URL=

# Perso.ai
PERSO_API_KEY=
PERSO_API_BASE_URL=https://api.perso.ai
NEXT_PUBLIC_PERSO_FILE_BASE_URL=https://portal-media.perso.ai

# Google OAuth / YouTube Data API
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Session and token encryption
SESSION_SECRET=
# Use at least 32 characters. Changing this after launch invalidates encrypted stored Google/YouTube tokens.
TOKEN_ENCRYPTION_KEY=
# Set to true only during a short migration window for legacy plaintext tokens.
ALLOW_LEGACY_PLAINTEXT_TOKENS=false

# Turso DB
TURSO_URL=
TURSO_AUTH_TOKEN=

# Gemini / Vertex AI metadata translation
GEMINI_API_KEY=
GOOGLE_VERTEX_PROJECT_ID=
GOOGLE_VERTEX_LOCATION=us-central1
# Paste the full service account JSON as a single-line env value in hosted environments.
GOOGLE_VERTEX_CREDENTIALS_JSON=

# Toss Payments
# Test mode: test_sk... or test_gsk...
# Production: live_sk... or live_gsk...
TOSS_SECRET_KEY=
TOSS_API_BASE_URL=https://api.tosspayments.com

# Background maintenance
# Must match the GitHub Actions repository secret CRON_SECRET.
CRON_SECRET=
# Comma-separated admin emails for the operations dashboard.
OPERATIONS_ADMIN_EMAILS=admin@example.com

# Chrome Extension
NEXT_PUBLIC_EXTENSION_ID=

# GitHub Actions repository settings, not app env:
# - Variable: PROD_BASE_URL=https://your-domain.com
# - Secret: CRON_SECRET=<same value as app CRON_SECRET>
