{
  "name": "creatordub-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "analyze": "node -e \"process.env.ANALYZE='true';require('child_process').execSync('next build --webpack',{stdio:'inherit',env:process.env})\"",
    "start": "next start",
    "start:test": "next start -p 3100",
    "start:test2": "next start -p 3101",
    "test:lighthouse:prod": "lighthouse http://localhost:3100/ --quiet --chrome-flags=\"--headless=new\" --output=json --output=html --output-path=./tests/snapshots/lighthouse-prod --only-categories=performance,accessibility,best-practices,seo",
    "test:lighthouse:prod2": "lighthouse http://localhost:3101/ --quiet --chrome-flags=\"--headless=new\" --output=json --output=html --output-path=./tests/snapshots/lighthouse-prod2 --only-categories=performance,accessibility,best-practices,seo",
    "lint": "eslint",
    "test:e2e": "playwright test",
    "test:install": "playwright install chromium",
    "test:lighthouse": "lighthouse http://localhost:3000/ --quiet --chrome-flags=\"--headless=new\" --output=json --output=html --output-path=./tests/snapshots/lighthouse --only-categories=performance,accessibility,best-practices,seo",
    "test:lighthouse:parse": "node tests/parse-lighthouse.mjs",
    "test:lighthouse:issues": "node tests/parse-lighthouse-issues.mjs",
    "test:lighthouse:prod:parse": "node tests/parse-lighthouse-prod.mjs",
    "test:lighthouse:a11y": "node tests/parse-a11y-details.mjs",
    "test:lighthouse:prod2:parse": "node tests/parse-lighthouse-prod2.mjs",
    "test:lighthouse:gate": "node tests/lighthouse-gate.mjs",
    "test:cleanup": "node tests/kill-ports.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@libsql/client": "^0.17.2",
    "@tanstack/react-query": "^5.99.2",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "next": "16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "recharts": "^3.8.1",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.4",
    "@next/eslint-plugin-next": "^16.2.4",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "eslint-config-next": "16.2.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "lighthouse": "^13.1.0",
    "tailwindcss": "^4.2.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.4"
  }
}
