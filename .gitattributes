# Auto-detect text files and normalize line endings
* text=auto

# Force LF for source files
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.json text eol=lf
*.css text eol=lf
*.md text eol=lf

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary

# GitHub language detection — exclude generated/vendored files
tests/snapshots/** linguist-generated
coverage/** linguist-generated
